# Copie para .env e ajuste

# ---------- Portas expostas no host ----------
BACKEND_PORT=13000
POSTGRES_PORT=15432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---------- PostgreSQL ----------
POSTGRES_USER=corretor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=corretor
# Usado pelo Prisma CLI rodando NA MÁQUINA HOST (migrations, studio).
DATABASE_URL="postgresql://corretor:change-me@localhost:15432/corretor"

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
S3_BUCKET=corretor-docs
# IP da máquina dev na LAN — usado para URLs presigned acessíveis do device físico
S3_PUBLIC_ENDPOINT=http://192.168.1.100:9000

# ---------- RabbitMQ ----------
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=change-me

# ---------- JWT — TROQUE em produção ----------
# Gere com: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---------- Seed idempotente ----------
RUN_SEED=true

# ---------- Firebase Cloud Messaging ----------
# Service account JSON em base64 (gere com: base64 -w 0 service-account.json).
# Console → Project Settings → Service Accounts → Generate new private key.
# Deixe vazio para rodar em modo STUB (apenas loga).
FIREBASE_SERVICE_ACCOUNT=

# ---------- Simuladores MVP ----------
# Definir false para desligar individualmente
PAGAMENTO_SIMULADOR=true
OPERADORA_SIMULADOR=true
CPF_SIMULADOR=true
OCR_SIMULADOR=true
LEMBRETES_SIMULADOR=true

# ---------- Fuso horário (Node respeita TZ automaticamente) ----------
# Usado pela IA para interpretar "amanhã", "próxima segunda", etc.
TZ=America/Sao_Paulo

# ---------- IA / Gemini (chat conversacional) ----------
# Obtenha em https://aistudio.google.com/apikey (gratuito).
# Deixe vazio para rodar em modo STUB (AiChatService loga aviso e retorna eco).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 'free' aplica anonymizer (mascara CPF/email/telefone antes de enviar pro Gemini).
# 'paid' envia literal (tier pago não usa prompts para treino).
GEMINI_TIER=free
AI_CHAT_MAX_HOPS=8
AI_CHAT_MAX_TOKENS=2000
